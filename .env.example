# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@localhost:5432/mitsuketa

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── First Admin (auto-created on startup if no users exist) ───────────────────
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_EMAIL=admin@mitsuketa.local

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
